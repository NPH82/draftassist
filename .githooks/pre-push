#!/usr/bin/env sh

set -eu

ROOT_DIR="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

echo "[pre-push] Running security audit gate"
(cd "$ROOT_DIR" && npm run security:audit)

echo "[pre-push] Running backend unit tests with coverage threshold"
(cd "$ROOT_DIR/backend" && npm run test:coverage)

echo "[pre-push] Running frontend unit tests with coverage threshold"
(cd "$ROOT_DIR/frontend" && npm run test:coverage)

echo "[pre-push] Running docs-update guard"
(cd "$ROOT_DIR" && npm run docs:check)

echo "[pre-push] Passed: audit + tests + coverage + docs gates"
